component FeatureCard {
    props {
        icon:  String
        title: String
        desc:  String
        tag:   String
    }
    view {
        div class="feature-card" {
            div class="feature-top" {
                div class="feature-icon-wrap" {
                    span class="feature-icon" { "{icon}" }
                }
                span class="feature-tag" { "{tag}" }
            }
            h3 class="feature-title" { "{title}" }
            p class="feature-desc" { "{desc}" }
        }
    }
    style {
        .feature-card {
            background: #fff;
            border: 1px solid var(--color-border);
            border-radius: var(--radius-md);
            padding: var(--spacing-lg);
            display: flex;
            flex-direction: column;
            gap: var(--spacing-sm);
            min-width: 0;
            position: relative;
            overflow: hidden;
            transition: border-color 0.15s, transform 0.15s;
        }
        .feature-card::before {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            bottom: 0;
            width: 3px;
            background: var(--color-primary);
            opacity: 0;
            transition: opacity 0.15s;
        }
        .feature-card:hover {
            border-color: rgba(200, 75, 17, 0.3);
            transform: translateY(-2px);
        }
        .feature-card:hover::before { opacity: 1; }
        .feature-top {
            display: flex;
            align-items: center;
            justify-content: space-between;
            gap: var(--spacing-sm);
        }
        .feature-icon-wrap {
            width: 2rem;
            height: 2rem;
            border-radius: var(--radius-md);
            background: var(--color-background);
            border: 1px solid var(--color-border);
            display: flex;
            align-items: center;
            justify-content: center;
            flex-shrink: 0;
        }
        .feature-icon { font-size: 1rem; line-height: 1; }
        .feature-title {
            font-size: 0.875rem;
            font-weight: 800;
            color: var(--color-text);
            line-height: 1.3;
            letter-spacing: -0.01em;
        }
        .feature-tag {
            font-size: 0.58rem;
            font-weight: 800;
            text-transform: uppercase;
            letter-spacing: 0.08em;
            color: var(--color-primary);
            background: rgba(200, 75, 17, 0.07);
            border: 1px solid rgba(200, 75, 17, 0.18);
            padding: 2px 6px;
            border-radius: 2px;
            white-space: nowrap;
            flex-shrink: 0;
            font-family: var(--font-mono);
        }
        .feature-desc {
            font-size: 0.825rem;
            color: var(--color-muted);
            line-height: 1.65;
            overflow-wrap: break-word;
        }
    }
}
