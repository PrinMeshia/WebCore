page "examples" {
    div class="page-header" {
        div class="page-header-badge" { "6 projects • open source" }
        h1 { "Examples" }
        p class="page-sub" {
            "Complete projects built with WebCore — each compiles to a standalone "
            code { "dist/" }
            " with no framework or bundler."
        }
    }

    div class="examples-grid" {
        div class="example-card" {
            div class="example-card-top" {
                span class="example-emoji" { "🔢" }
                div class="example-card-meta" {
                    code class="example-tag" { "counter" }
                    div class="example-chips" {
                        span class="chip" { "state" }
                        span class="chip" { "computed" }
                        span class="chip" { "@if" }
                    }
                }
            }
            h3 { "Counter" }
            p { "The ideal starting point — reactive counter with increment, decrement and variable step. Demonstrates state, computed vars and conditional directives." }
            pre class="code-block" { "cd examples/counter && webc serve" }
        }

        div class="example-card" {
            div class="example-card-top" {
                span class="example-emoji" { "✅" }
                div class="example-card-meta" {
                    code class="example-tag" { "todo" }
                    div class="example-chips" {
                        span class="chip" { "@for key" }
                        span class="chip" { "bind:value" }
                        span class="chip" { "lifecycle" }
                    }
                }
            }
            h3 { "Todo" }
            p {
                "Todo list with add, toggle and delete. Demonstrates "
                code { "@for" }
                " with key-diffing, "
                code { "@if" }
                ", computed vars and CSS nesting."
            }
            pre class="code-block" { "cd examples/todo && webc serve" }
        }

        div class="example-card" {
            div class="example-card-top" {
                span class="example-emoji" { "📝" }
                div class="example-card-meta" {
                    code class="example-tag" { "blog" }
                    div class="example-chips" {
                        span class="chip chip-accent" { "routing" }
                        span class="chip" { "$route" }
                        span class="chip" { "store" }
                    }
                }
            }
            h3 { "Blog" }
            p {
                "Multi-page blog with parameterized routes ("
                code { "/post/:slug" }
                "). Shows SPA routing, route params and the global store for theming."
            }
            pre class="code-block" { "cd examples/blog && webc serve" }
        }

        div class="example-card" {
            div class="example-card-top" {
                span class="example-emoji" { "📋" }
                div class="example-card-meta" {
                    code class="example-tag" { "forms" }
                    div class="example-chips" {
                        span class="chip chip-warning" { "validate:" }
                        span class="chip" { "@error" }
                        span class="chip" { "bind:" }
                    }
                }
            }
            h3 { "Forms" }
            p {
                "SignupForm and ContactForm with full declarative validation — required, email, minlength, maxlength, pattern and "
                code { "@error" }
                " blocks."
            }
            pre class="code-block" { "cd examples/forms && webc serve" }
        }

        div class="example-card" {
            div class="example-card-top" {
                span class="example-emoji" { "🌍" }
                div class="example-card-meta" {
                    code class="example-tag" { "i18n" }
                    div class="example-chips" {
                        span class="chip chip-secondary" { "t()" }
                        span class="chip" { "plural" }
                        span class="chip" { "setLocale" }
                    }
                }
            }
            h3 { "i18n" }
            p { "Internationalisation — t() calls, plural forms (items_one / items_other), positional parameters and reactive locale switching." }
            pre class="code-block" { "cd examples/i18n && webc serve" }
        }

        div class="example-card example-card-featured" {
            div class="example-card-top" {
                span class="example-emoji" { "📚" }
                div class="example-card-meta" {
                    code class="example-tag" { "docs" }
                    div class="example-chips" {
                        span class="chip chip-accent" { "SPA" }
                        span class="chip" { "slots" }
                        span class="chip" { "on:mount" }
                    }
                }
            }
            h3 { "Docs — this site" }
            p { "This documentation site — 5 pages, SPA routing, named slots, sidebar TOC, copy-to-clipboard, announcement bar and minimal design system." }
            pre class="code-block" { "cd examples/docs && webc serve" }
        }
    }

    section class="doc-section" {
        h2 { "Project structure" }
        p { "All examples follow the same layout:" }
        pre class="code-block" {
"my-project/
├── webc.toml          # name, entry point, mode (dev | prod)
├── theme.toml         # design tokens (colors, spacing, fonts)
├── public/
│   └── styles.css     # optional global styles
└── src/
    ├── app.webc       # routes + layout declaration
    ├── layouts/
    │   └── Main.webc
    ├── pages/
    │   └── home.webc
    └── components/
        └── Counter.webc"
        }
    }

    section class="doc-section" {
        h2 { "Create a new project" }
        p {
            code { "webc new" }
            " scaffolds a complete project — webc.toml, theme.toml, layout, home page and a reactive Counter component."
        }
        pre class="code-block" {
"webc new my-app
cd my-app
webc serve        # dev server with HMR"
        }
    }

    section class="doc-section" {
        h2 { "Production build" }
        p {
            code { "webc build" }
            " produces a minified "
            code { "dist/" }
            " with inlined CSS, asset SRI and bundle analysis."
        }
        pre class="code-block" {
"webc build

Bundle Analysis:
  ✓ state              312 b
  ✓ signals ($effect)  428 b
  ✓ bindFor            512 b
  - http               (tree-shaken)
  - router             (tree-shaken)
Total JS: 1.35 KB"
        }
    }
}
