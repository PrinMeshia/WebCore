page "syntax" {
    div class="page-header" {
        h1 { "Syntax Reference" }
        p class="page-sub" {
            "Complete reference for the "
            code { ".webc" }
            " language — all constructs, directives and built-ins."
        }
    }

    div class="quick-ref" {
        code { "app \{\}" }
        code { "layout \{\}" }
        code { "page \{\}" }
        code { "component \{\}" }
        code { "store \{\}" }
        code { "state \{\}" }
        code { "computed \{\}" }
        code { "props \{\}" }
        code { "@if / @else" }
        code { "@for" }
        code { "@for key=" }
        code { "@for item, i" }
        code { "@switch" }
        code { "bind:" }
        code { "@error" }
        code { "on:click=" }
        code { "on:mount" }
        code { "on:destroy" }
        code { "emit()" }
        code { "t()" }
        code { "$store." }
        code { "$route." }
        code { "slot content" }
        code { "link to=" }
        code { "validate:" }
        code { "http \{\}" }
        code { "head \{\}" }
        code { "$query." }
        code { "class:" }
        code { "|debounce" }
        code { "ref:" }
        code { "style:" }
        code { "slot default" }
        code { "webc:transition" }
        code { "webc:img" }
        code { "img fingerprint" }
    }

    section class="doc-section" {
        h2 { "Application" }
        p {
            "The "
            code { "app" }
            " block is the entry point. It declares the theme, layout and route table."
        }
        pre class="code-block" {
"app MyApp \{
    theme: \"default\"
    layout: MainLayout
    routes \{
        \"/\":      HomePage
        \"/about\": AboutPage
    \}
\}"
        }
    }

    section class="doc-section" {
        h2 { "Layout" }
        p {
            "Layouts wrap every page. Use "
            code { "slot content" }
            " for the page injection point. Named slots support multi-zone layouts."
        }
        pre class="code-block" {
"// Single-slot layout
layout MainLayout \{
    header \{ nav \{ link to=\"/\" \{ \"Home\" \} \} \}
    main   \{ slot content \}
    footer \{ p \"2025 My App\" \}
\}

// Multi-zone layout (named slots)
layout DashLayout \{
    header \{ slot header  \}
    aside  \{ slot sidebar \}
    main   \{ slot content \}
\}"
        }
        p {
            "Pages fill named slots with "
            code { "slot name \{ ... \}" }
            " blocks."
        }
        pre class="code-block" {
"page \"dashboard\" \{
    slot header  \{ h1 \"Dashboard\" \}
    slot sidebar \{ nav \{ link to=\"/\" \"Home\" \} \}
    p \"Main content\"   // -> default content slot
\}"
        }
    }

    section class="doc-section" {
        h2 { "Elements and content" }
        p { "Any standard HTML tag is valid. Inline text or block children — both work." }
        pre class="code-block" {
"div class=\"container\" \{
    h1 \"Hello world\"
    p  \"Plain text node\"
    p  \{ \"Mixed: \" strong \{ \"bold\" \} \" and plain.\" \}
    img src=\"/logo.png\" alt=\"Logo\"
    ul \{
        li \"Item one\"
        li \"Item two\"
    \}
\}"
        }
    }

    section class="doc-section" {
        h2 { "Interpolation" }
        p {
            "Expressions inside "
            code { "\{\}" }
            " are evaluated reactively. They support arithmetic, comparisons, function calls and computed variables."
        }
        pre class="code-block" {
"p \"Count: \{count\}\"
p \"Next: \{count + 1\}\"
p \"Max: \{max(a, b)\}\"
p \"Full name: \{fullName\}\"    // computed var
div class=\{dynamicClass\} \{ \}"
        }
    }

    section class="doc-section" {
        h2 { "Control flow" }
        pre class="code-block" {
"// Conditional
@if count > 0 \{
    p \"Positive\"
\} @else \{
    p \"Zero or negative\"
\}

// List — full re-render on change
@for item in items \{
    li \"\{item\}\"
\}

// List with key — DOM diffing (only changed nodes patched)
@for post key=post.id in posts \{
    article \"\{post.title\}\"
\}

// Complex key expression (v2.1)
@for item key=\{item.category + \":\" + item.id\} in items \{
    li \"\{item.name\}\"
\}

// Validation error block
@error \"email\" \{
    span class=\"error\" \"Invalid email\"
\}"
        }
        div class="callout" {
            strong { "Key diffing: " }
            "The "
            code { "key=" }
            " expression must be unique within the list. Use "
            code { "item.id" }
            " or "
            code { "item.slug" }
            " for simple paths, or "
            code { "key={expr}" }
            " for computed keys (v2.1). Added nodes are inserted, removed ones deleted, unchanged ones stay — preserving focus and animation state."
        }
    }

    section class="doc-section" {
        h2 {
            "@for with index "
            span class="version-tag" { "v1.2.0" }
        }
        p {
            "Add a second variable after "
            code { "," }
            " to receive the 0-based index of each item."
        }
        pre class="code-block" {
"@for item, i in items \{
    li \"\{i\}. \{item\}\"
\}

// Ranking with computed position
@for entry, rank in scores \{
    li \"#\{rank + 1\} — \{entry.name\}: \{entry.score\}\"
\}"
        }
    }

    section class="doc-section" {
        h2 {
            "@switch / @case / @default "
            span class="version-tag" { "v1.2.0" }
        }
        p {
            "Multi-branch directive — a readable alternative to chained "
            code { "@if" }
            " / "
            code { "@else" }
            ". Compiled to an "
            code { "@if" }
            " chain at parse time — zero runtime overhead."
        }
        pre class="code-block" {
"@switch status \{
    @case \"active\"   \{ span class=\"badge green\"  \"Active\"   \}
    @case \"pending\"  \{ span class=\"badge yellow\" \"Pending\"  \}
    @case \"archived\" \{ span class=\"badge gray\"   \"Archived\" \}
    @default          \{ span class=\"badge\"        \"Unknown\"  \}
\}

// Expression switch
@switch count % 3 \{
    @case 0 \{ p \"Divisible by 3\" \}
    @case 1 \{ p \"Remainder 1\"    \}
    @case 2 \{ p \"Remainder 2\"    \}
\}"
        }
        div class="callout" {
            "The expression is compared with "
            code { "===" }
            " to each "
            code { "@case" }
            " value. "
            code { "@default" }
            " is optional — if omitted and no case matches, nothing is rendered."
        }
    }

    section class="doc-section" {
        h2 { "Events" }
        p {
            "Use "
            code { "on:<type>=\{expr\}" }
            " on any element. Multiple instructions can be separated by "
            code { ";" }
            ". Balanced braces inside the expression are allowed — object literals work directly (v2.1)."
        }
        pre class="code-block" {
"button on:click=\{count += 1\}                    \{ \"+\" \}
button on:click=\{count = max(0, count - 1)\}      \{ \"−\" \}
input  on:input=\{name = event.target.value\}
form   on:submit=\{handleSubmit\}

// Navigation
button on:click=\{webcore_navigate(\"/about\")\} \{ \"Go\" \}

// Multi-instruction handler
button on:click=\{items = [...items, newItem]; draft = \"\"\} \{ \"Add\" \}

// Object literal inline (v2.1 — no helper needed)
button on:click=\{items = [...items, \{text: draft, done: false\}]; draft = \"\"\} \{ \"Add\" \}

// Inter-component event
button on:click=\{emit(\"ping\", count)\} \{ \"Ping\" \}"
        }
    }

    section class="doc-section" {
        h2 { "Attributes" }
        pre class="code-block" {
"// Static string
div class=\"container\" id=\"main\"

// Boolean
input disabled
input required

// Dynamic expression
div class=\{dynamicClass\}
input value=\{count\}

// Validation attributes
input name=\"email\"
      validate:required=\"Email is required\"
      validate:email=\"Invalid address\"
      validate:minlength=\"3,At least 3 chars\""
        }
    }

    section class="doc-section" {
        h2 {
            "Two-way binding "
            span class="version-tag" { "v1.2.0" }
        }
        p {
            code { "bind:attr=\{var\}" }
            " is shorthand for the attribute + its update handler — keeps value and state in sync automatically."
        }
        pre class="code-block" {
"// bind:value syncs on every keystroke (on:input)
input type=\"text\" bind:value=\{name\}

// bind:checked syncs on toggle (on:change)
input type=\"checkbox\" bind:checked=\{accepted\}

// Equivalent long form (what bind: expands to)
input type=\"text\" value=\{name\} on:input=\{name = event.target.value\}"
        }
        div class="callout-tip" {
            code { "bind:value" }
            " uses "
            code { "on:input" }
            " (fires on every keystroke). "
            code { "bind:checked" }
            " uses "
            code { "on:change" }
            " (fires on toggle)."
        }
    }

    section class="doc-section" {
        h2 { "Navigation" }
        pre class="code-block" {
"// Declarative SPA link
link to=\"/about\" \{ \"About\" \}
link to=\"/about\" class=\"nav-link\" \{ \"About\" \}

// Programmatic
button on:click=\{webcore_navigate(\"/about\")\} \{ \"Go\" \}
button on:click=\{webcore_navigate(\"/user/\" + userId)\} \{ \"Profile\" \}"
        }
        div class="callout-tip" {
            "Navigation uses "
            code { "history.pushState" }
            " + fetch — no full page reload. "
            code { "on:destroy" }
            " hooks run automatically before each navigation."
        }
    }

    section class="doc-section" {
        h2 {
            "HTTP block "
            span class="version-tag" { "v1.3.0" }
        }
        p {
            "The "
            code { "http \{\}" }
            " block triggers a declarative JSON fetch inside "
            code { "DOMContentLoaded" }
            ". "
            code { "loading" }
            " and "
            code { "error" }
            " state variables are auto-injected — no need to declare them."
        }
        pre class="code-block" {
"component Posts \{
    state \{ posts: List = null \}
    http \{ get: \"/api/posts\"  into: posts \}
    view \{
        @if loading \{ p \"Loading...\" \}
        @if error   \{ p \"Error: \{error\}\" \}
        @for post in posts \{ li \"\{post.title\}\" \}
    \}
\}"
        }
        div class="callout" {
            code { "loading" }
            " is set to "
            code { "false" }
            " after the response (success or error). "
            code { "error" }
            " holds the error message if the fetch fails."
        }
    }

    section class="doc-section" {
        h2 {
            "Page head "
            span class="version-tag" { "v1.3.0" }
        }
        p {
            "The "
            code { "head \{\}" }
            " block inside a "
            code { "page" }
            " customizes the HTML "
            code { "<head>" }
            " — title and meta tags. Overrides the global title from "
            code { "webc.toml" }
            "."
        }
        pre class="code-block" {
"page \"article\" \{
    head \{
        title \"My Article\"
        meta description=\"A WebCore blog post\"
        meta og:title=\"My Article\"
    \}
    h1 \"Hello\"
\}"
        }
    }

    section class="doc-section" {
        h2 {
            "Query params "
            span class="version-tag" { "v1.3.0" }
        }
        p {
            "Access URL query string parameters with "
            code { "$query.<name>" }
            ". Tree-shaken: "
            code { "QUERY_PARAMS" }
            " is only emitted when at least one "
            code { "$query." }
            " reference is present."
        }
        pre class="code-block" {
"p \"Search: \{$query.search\}\"
p \"Page: \{$query.page\}\"
p \"Sort: \{$query.sort\}\""
        }
    }

    section class="doc-section" {
        h2 {
            "Conditional classes "
            span class="version-tag" { "v1.3.0" }
        }
        p {
            code { "class:name=\{expr\}" }
            " binds a CSS class to a boolean expression. The class is added when truthy, removed when falsy. Handled reactively by "
            code { "bindAttrs()" }
            "."
        }
        pre class="code-block" {
"div class:active=\{isOpen\} \{ \"Content\" \}
div class:active=\{isOpen\} class:hidden=\{!visible\} \{ \"Content\" \}
button class:disabled=\{count == 0\} on:click=\{count -= 1\} \{ \"-\" \}"
        }
        div class="callout-tip" {
            "Multiple "
            code { "class:" }
            " attributes can coexist on the same element. The class-toggle logic in "
            code { "bindAttrs()" }
            " is tree-shaken when unused."
        }
    }

    section class="doc-section" {
        h2 {
            "Debounced events "
            span class="version-tag" { "v1.3.0" }
        }
        p {
            "Add "
            code { "|debounce" }
            " after the event type to wrap the handler in a 300 ms "
            code { "setTimeout" }
            ". The handler only fires after 300 ms of inactivity."
        }
        pre class="code-block" {
"// Search field — avoids an API call on every keystroke
input on:input|debounce=\{search = event.target.value\}

// Works with any event type
input on:keyup|debounce=\{query = event.target.value\}"
        }
        div class="callout-tip" {
            "Useful for search inputs, list filters, or any handler that should wait for a pause in user activity."
        }
    }

    section class="doc-section" {
        h2 {
            "Parameterized routes "
            span class="version-tag" { "v1.1.0" }
        }
        p {
            "Route segments prefixed with "
            code { ":" }
            " capture dynamic values. Access them in views with "
            code { "\{$route.paramName\}" }
            "."
        }
        pre class="code-block" {
"// src/app.webc
app MyApp \{
    routes \{
        \"/\":           HomePage
        \"/post/:slug\": PostPage
        \"/user/:id\":   UserPage
    \}
\}

// src/pages/post.webc
page \"post\" \{
    h1 \"Article: \{$route.slug\}\"
\}

// Navigate to a parameterized route
link to=\"/post/hello-world\" \{ \"Hello World\" \}
button on:click=\{webcore_navigate(\"/user/\" + userId)\} \{ \"Profile\" \}"
        }
        div class="callout" {
            "The compiler generates a "
            code { "ROUTES[]" }
            " array with RegExp patterns and a "
            code { "ROUTE_PARAMS" }
            " object updated on every navigation. Both are tree-shaken when no parameterized routes are declared."
        }
    }

    section class="doc-section" {
        h2 {
            "DOM references "
            span class="version-tag" { "v1.4.0" }
        }
        p {
            code { "ref:name=true" }
            " registers a direct reference to the element in "
            code { "refs['name']" }
            " after "
            code { "DOMContentLoaded" }
            ". No "
            code { "querySelector" }
            " needed — useful for focus management and imperative DOM calls."
        }
        pre class="code-block" {
"component SearchBar \{
    state \{ query: String = \"\" \}
    on:mount \{
        refs['searchInput'].focus();
    \}
    view \{
        input ref:searchInput=true
              on:input=\{query = event.target.value\}
              placeholder=\"Search...\"
    \}
\}"
        }
        div class="callout" {
            "The HTML attribute "
            code { "data-webcore-ref=\"name\"" }
            " is emitted on the element. "
            code { "const refs = \{\}" }
            " is declared at block scope and populated in "
            code { "DOMContentLoaded" }
            ". Tree-shaken via "
            code { "has_refs" }
            " flag — zero overhead when unused."
        }
    }

    section class="doc-section" {
        h2 {
            "Dynamic inline styles "
            span class="version-tag" { "v1.4.0" }
        }
        p {
            code { "style:prop=\{expr\}" }
            " binds a CSS property to a reactive expression. Applied via "
            code { "el.style.setProperty(...)" }
            " in "
            code { "bindAttrs()" }
            ". Dashes in property names are preserved."
        }
        pre class="code-block" {
"div style:color=\{textColor\} \{ \"Colored text\" \}
div style:background-color=\{bg\}
    style:font-size=\{size\}
    \{ \"Multiple style bindings\" \}

// Coexists with static style and class:
div style=\"padding: 1rem\"
    style:color=\{textColor\}
    class:active=\{isOpen\}
    \{ \"Content\" \}"
        }
        div class="callout-tip" {
            "Emits "
            code { "data-webcore-style-color=\"myColor\"" }
            " on the element. Tree-shaken via "
            code { "has_style_binding" }
            " flag. Can coexist with static "
            code { "style=\"...\"" }
            " and "
            code { "class:" }
            " on the same element."
        }
    }

    section class="doc-section" {
        h2 {
            "Slot default content "
            span class="version-tag" { "v1.4.0" }
        }
        p {
            "Layouts can define fallback content for named slots. If the page fills the slot, the page content is used; otherwise the layout's default content is shown."
        }
        pre class="code-block" {
"// Layout with default sidebar content
layout AppLayout \{
    aside \{
        slot sidebar \{
            p \"Default navigation\"
            link to=\"/\" \{ \"Home\" \}
        \}
    \}
    main \{ slot content \}
\}

// Page A — overrides sidebar
page \"dashboard\" \{
    slot sidebar \{
        nav \{ link to=\"/settings\" \{ \"Settings\" \} \}
    \}
    h1 \"Dashboard\"
\}

// Page B — uses default sidebar
page \"about\" \{
    h1 \"About\"
\}"
        }
        div class="callout" {
            "Before v1.4.0, unfilled named slots were silently dropped. The default "
            code { "content" }
            " slot still uses the page body as-is."
        }
    }

    section class="doc-section" {
        h2 {
            "CSS transitions "
            span class="version-tag" { "v1.4.0" }
        }
        p {
            code { "webc:transition=\"name\"" }
            " adds enter/leave CSS animations to a conditional element. Works with "
            code { "@if" }
            " blocks — the element enters with an enter animation and leaves with an exit animation."
        }
        pre class="code-block" {
"// Fade transition (opacity 0→1)
@if isOpen \{
    div webc:transition=\"fade\" \{
        p \"This panel fades in and out\"
    \}
\}

// Slide transition (translateY -10px→0)
@if showPanel \{
    div webc:transition=\"slide\" \{
        p \"This panel slides down\"
    \}
\}"
        }
        div class="callout" {
            "Built-in transitions: "
            code { "fade" }
            " (opacity) and "
            code { "slide" }
            " (translateY). The "
            code { "data-webcore-transition=\"name\"" }
            " HTML attribute is emitted; JS injects the CSS and uses "
            code { "requestAnimationFrame" }
            " + "
            code { "transitionend" }
            ". Tree-shaken via "
            code { "has_transition" }
            " flag."
        }
    }

    section class="doc-section" {
        h2 {
            "Optimized images "
            span class="version-tag" { "v1.5.0" }
        }
        p {
            "The "
            code { "webc:img" }
            " directive on an "
            code { "img" }
            " element triggers a full compile-time transformation: lazy loading, async decoding and real dimensions read from "
            code { "public/" }
            " — preventing layout shift (CLS). Zero JS emitted."
        }
        pre class="code-block" {
"// webc:img is stripped from the HTML output
img webc:img src=\"/hero.png\" alt=\"Hero\"
img webc:img src=\"/logo.svg\" alt=\"Logo\" class=\"logo\"

// Compiled output:
// <img src=\"/assets/hero.png\" loading=\"lazy\" decoding=\"async\"
//      width=\"1200\" height=\"630\" alt=\"Hero\">"
        }
        div class="callout" {
            "If "
            code { "alt" }
            " is missing the compiler emits "
            code { "warning[a11y]: <img> with webc:img is missing alt attribute" }
            ". Compilation continues — it is a warning, not an error. Dimensions are read at build time via the "
            code { "imagesize" }
            " crate (no full image decode)."
        }
    }

    section class="doc-section" {
        h2 {
            "Image fingerprinting "
            span class="version-tag" { "v1.5.0" }
        }
        p {
            "At "
            code { "webc build" }
            ", every image in "
            code { "public/" }
            " receives a FNV-1a 32-bit content hash in its filename. All "
            code { "src" }
            " and "
            code { "url(...)" }
            " references in generated HTML and CSS are rewritten automatically."
        }
        pre class="code-block" {
"// public/ → dist/assets/
logo.png          →  logo.a3f9c1b2.png
hero.jpg          →  hero.d4e2f1a0.jpg
icons/arrow.svg   →  icons/arrow.7b3c9e4d.svg

// Covered extensions:
// .png  .jpg  .jpeg  .gif  .webp  .svg  .ico  .avif"
        }
        div class="callout-tip" {
            "Always-on — no configuration needed. The browser can cache images indefinitely ("
            code { "Cache-Control: max-age=31536000, immutable" }
            "). When image content changes, the filename changes too, so the new version is fetched automatically."
        }
    }

    section class="doc-section" {
        h2 {
            "CSS nesting "
            span class="version-tag" { "v2.0.0" }
        }
        p {
            "Nested rules using the "
            code { "&" }
            " selector are now valid inside "
            code { "style {}" }
            " blocks. They are flattened to scoped CSS at compile time."
        }
        pre class="code-block" {
"component Card {
    view { div class=\"card\" { p \"content\" } }
    style {
        .card {
            padding: 1rem;
            &:hover { background: #f5f5f5; }
            & > p { color: #333; }
            &::before { content: \"\"; }
        }
    }
}"
        }
        div class="callout" {
            "The "
            code { "&" }
            " selector is replaced by the scoped parent selector at build time. Output is valid, flattened CSS — no native browser nesting required."
        }
    }

    section class="doc-section" {
        h2 {
            "Error aggregation "
            span class="version-tag" { "v2.0.0" }
        }
        p {
            code { "webc build" }
            " now collects ALL compile errors and reports them together, instead of stopping at the first error — just like the Rust compiler."
        }
        pre class="code-block" {
"// Before (v1.x): stops at first error
error: missing layout \"Main\" (available: none)

// After (v2.0): all errors reported at once
error[compile]: missing layout \"Main\" (available: none)
error[compile]: component \"Counter\" not found
error[parse]: src/pages/home.webc:3:12 — expected '}'

3 error(s) found."
        }
    }

    section class="doc-section" {
        h2 {
            "Bundle analysis "
            span class="version-tag" { "v2.0.0" }
        }
        p {
            "After a successful "
            code { "webc build" }
            ", the compiler prints a bundle analysis table showing which runtime features are included vs. tree-shaken."
        }
        pre class="code-block" {
"Bundle Analysis:
  ✓ state            312 b
  ✓ signals ($effect) 428 b
  ✓ dom init          89 b
  ✓ bindFor          512 b
  - bindIf           (tree-shaken)
  - http             (tree-shaken)
  ✓ router           634 b
Total JS: 1.98 KB"
        }
        div class="callout-tip" {
            "Features not used by your project are tree-shaken automatically. The analysis helps you understand what is contributing to the final JS bundle."
        }
    }

    section class="doc-section" {
        h2 {
            "Fine-grained signals "
            span class="version-tag" { "v2.0.0" }
        }
        p {
            "WebCore v2 uses fine-grained reactive signals internally. "
            code { "$effect(fn)" }
            " replaces the v1 "
            code { "VARS.forEach(v=>S.on(v,fn))" }
            " pattern — dependency tracking is automatic."
        }
        pre class="code-block" {
"// v1.x (manual subscription list)
VARS.forEach(v => S.on(v, fn));

// v2.0 (automatic tracking via $effect)
$effect(() => {
    el.textContent = S.get('count');
    // count is tracked automatically
});"
        }
        div class="callout" {
            "Components only re-render when their actual dependencies change. "
            code { "var __wcfx" }
            " tracks the currently running effect; "
            code { "S.get()" }
            " records which effect is subscribed to each key."
        }
    }
}
