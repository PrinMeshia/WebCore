// WebCore Grammar - Pest PEG Parser
// ==================================

// Whitespace and comments (silent rules)
WHITESPACE = _{ " " | "\t" | "\r" | "\n" }
COMMENT = _{ "//" ~ (!"\n" ~ ANY)* ~ "\n"? | "/*" ~ (!"*/" ~ ANY)* ~ "*/" }

// Document structure
document = { SOI ~ top_level_item* ~ EOI }
top_level_item = _{ app_decl | store_decl | layout_decl | page_decl | component_decl | import_decl }
import_decl = { "import" ~ identifier ~ "from" ~ string_literal }

// ============ APP DECLARATION ============
app_decl = { "app" ~ identifier ~ "{" ~ app_body ~ "}" }
app_body = { app_field* }
app_field = { app_theme | app_layout | app_routes | head_block }
app_theme = { "theme" ~ ":" ~ string_literal }
app_layout = { "layout" ~ ":" ~ identifier }
app_routes = { "routes" ~ "{" ~ route_entry* ~ "}" }
route_entry = { string_literal ~ ":" ~ identifier ~ ("each" ~ identifier)? }

// ============ STORE DECLARATION ============
store_decl = { "store" ~ "{" ~ (state_def | computed_block)* ~ "}" }

// ============ LAYOUT DECLARATION ============
layout_decl = { "layout" ~ identifier ~ "{" ~ element* ~ "}" }

// ============ PAGE DECLARATION ============
page_decl = { "page" ~ string_literal ~ "{" ~ head_block? ~ element* ~ "}" }

// ============ HEAD BLOCK (inside page) ============
head_block = { "head" ~ "{" ~ head_item* ~ "}" }
head_item  = _{ head_title | head_meta | head_favicon }
head_title = { "title" ~ string_literal }
head_meta  = { "meta" ~ meta_key ~ "=" ~ string_literal }
head_favicon = { "favicon" ~ string_literal }
// meta_key allows og:title, twitter:card (colon namespace) and hyphenated
// standard meta names (theme-color, apple-mobile-web-app-capable, …).
meta_key   = @{ (ASCII_ALPHA | "_") ~ (ASCII_ALPHANUMERIC | "_" | ":" | "-")* }

// ============ COMPONENT DECLARATION ============
component_decl = { "component" ~ identifier ~ "{" ~ component_body ~ "}" }
component_body = { component_section* }
component_section = _{ props_block | state_block | computed_block | on_mount_block | on_destroy_block | watch_block | http_block | view_block | style_block | element }

// ============ HTTP BLOCK (inside component) ============
http_block       = { "http" ~ "{" ~ http_field* ~ "}" }
http_field       = { http_field_name ~ ":" ~ http_field_value }
http_field_name  = @{ ASCII_ALPHA+ }
http_field_value = { string_literal | identifier }

// Computed state block
computed_block = { "computed" ~ "{" ~ computed_def* ~ "}" }
computed_def = { identifier ~ "=" ~ computed_rhs }
computed_rhs = @{ (!"\n" ~ !"\r" ~ !"}" ~ ANY)+ }

// on:mount / on:destroy lifecycle hooks — recursive brace matching (any nesting depth)
on_mount_block = { "on:mount" ~ on_mount_body }
on_destroy_block = { "on:destroy" ~ on_mount_body }
watch_block = { "$watch" ~ identifier ~ "=>" ~ on_mount_body }
on_mount_body    = @{ "{" ~ on_mount_content* ~ "}" }
on_mount_content =  _{ on_mount_nested | (!("{" | "}") ~ ANY) }
on_mount_nested  =  _{ "{" ~ on_mount_content* ~ "}" }

// Props block
props_block = { "props" ~ "{" ~ prop_def* ~ "}" }
prop_def = { identifier ~ (":" ~ type_name)? ~ ("=" ~ value)? }

// State block
state_block = { "state" ~ "{" ~ state_def* ~ "}" }
state_def = { identifier ~ ":" ~ type_name ~ ("=" ~ value)? }

// View block
view_block = { "view" ~ "{" ~ element* ~ "}" }

// Style block
style_block = { "style" ~ "{" ~ style_item* ~ "}" }
style_item = _{ media_block | keyframes_block | style_rule }
media_block = { "@media" ~ media_query ~ "{" ~ style_rule* ~ "}" }
media_query = @{ (!"{" ~ ANY)+ }
style_rule = { selector ~ "{" ~ (style_property | nested_rule)* ~ "}" }
nested_rule = { nested_selector ~ "{" ~ style_property* ~ "}" }
nested_selector = @{ "&" ~ (ASCII_ALPHANUMERIC | "-" | "_" | "." | "#" | ":" | "[" | "]" | "=" | "\"" | " " | ">" | "+" | "~" | "*" | "(" | ")" | ",")* }
selector = @{ (ASCII_ALPHANUMERIC | "-" | "_" | "." | "#" | ":" | "[" | "]" | "=" | "\"" | " " | ">" | "+" | "~" | "*" | "(" | ")" | ",")+ }
style_property = { property_name ~ ":" ~ property_value ~ ";"? }
property_name = @{ (ASCII_ALPHA | "-")+ }
property_value = @{ (!(";" | "}") ~ ANY)+ }
keyframes_block = {
    "@keyframes" ~ identifier ~
    "{" ~
    keyframe_step* ~
    "}"
}
keyframe_step = {
    keyframe_selector ~
    "{" ~ style_property* ~ "}"
}
keyframe_selector = @{ (ASCII_DIGIT+ ~ "%" | "from" | "to") ~ ("," ~ WHITESPACE* ~ (ASCII_DIGIT+ ~ "%" | "from" | "to"))* }

// ============ ELEMENTS (VIEW CONTENT) ============
element = { control_flow | slot_element | fragment_element | tag_element | text_element }

// Fragment shorthand: <>...</> renders children inline with no wrapper tag
fragment_element = { "<>" ~ element* ~ "</>" }

// Control flow: @for, @if, @switch, @error, @loading, @catch, @defer
control_flow = { for_loop | if_statement | switch_statement | error_block | loading_block | catch_block | defer_block }

for_loop = { "@for" ~ identifier ~ ("," ~ identifier)? ~ for_key_decl? ~ "in" ~ expression ~ "{" ~ element* ~ "}" }
for_key_decl = { "key" ~ "=" ~ for_key_value }
for_key_value = { for_key_braced | for_key_expr }
for_key_braced = { "{" ~ expression_content ~ "}" }
for_key_expr = @{ (ASCII_ALPHANUMERIC | "_" | "." | "[" | "]" | "$")+ }

if_statement = { "@if" ~ expression ~ "{" ~ element* ~ "}" ~ else_branch? }
// else_if_stmt matches the `if cond { ... }` fragment after `@else` (no `@` prefix)
else_if_stmt = { "if" ~ expression ~ "{" ~ element* ~ "}" ~ else_branch? }
else_branch = { "@else" ~ ("{" ~ element* ~ "}" | else_if_stmt | if_statement) }

// Switch: @switch expr { @case val { ... } @default { ... } }
// switch_expr stops at { or newline (avoids lookahead ambiguity with @case inside the body)
switch_statement = { "@switch" ~ switch_expr ~ "{" ~ (case_clause | default_clause)* ~ "}" }
switch_expr      = @{ (!("{" | "\n") ~ ANY)+ }
case_clause      = { "@case" ~ case_value ~ "{" ~ element* ~ "}" }
default_clause   = { "@default" ~ "{" ~ element* ~ "}" }
case_value       = @{ (!("{" | "}") ~ ANY)+ }

// Form validation error display: @error "fieldname" { ... }
error_block = { "@error" ~ string_literal ~ "{" ~ element* ~ "}" }

// HTTP state sugar: @loading { ... } = shorthand for @if loading { ... }
loading_block = { "@loading" ~ "{" ~ element* ~ "}" }

// HTTP error sugar: @catch { ... } = shorthand for @if error { ... }
catch_block = { "@catch" ~ "{" ~ element* ~ "}" }

// Lazy-render: @defer { ... } hides content until after DOMContentLoaded
defer_block = { "@defer" ~ "{" ~ element* ~ "}" }

// Slot element: placeholder (`slot header`) or content provision (`slot header { ... }`)
slot_element = { ("slot" ~ identifier ~ "{" ~ element* ~ "}") | ("slot" ~ identifier?) }

// Tag element (HTML-like or Component)
tag_element = { tag_name ~ attribute* ~ tag_content? }
tag_name = @{ (ASCII_ALPHA | "_") ~ (ASCII_ALPHANUMERIC | "_" | "-")* }
tag_content = { string_with_interpolation | "{" ~ mixed_content* ~ "}" }
// Silent: contributes string/element pairs directly to tag_content's children
mixed_content = _{ string_with_interpolation | element }

// Text element (standalone string)
text_element = { string_with_interpolation }

// ============ ATTRIBUTES ============
// attribute: ordered choice — spread first, then shorthand prop, then regular name=value
attribute = { spread_attr | shorthand_attr | (attr_name ~ "=" ~ attr_value) }
// Spread all properties of an object onto the element: `...obj`
spread_attr = { "..." ~ identifier }
// Shorthand prop binding: `{count}` ≡ `count={count}`
shorthand_attr = { "{" ~ identifier ~ "}" }
attr_name = @{ (ASCII_ALPHA | "_" | "-" | ":" | "|")+ }
attr_value = { expression_attr | string_literal | "true" | "false" }
expression_attr = { "{" ~ expression_content ~ "}" }
expression_content = @{ (expr_brace_seq | (!"}" ~ !"{" ~ ANY))* }
expr_brace_seq = @{ "{" ~ (expr_brace_seq | (!("}" | "{") ~ ANY))* ~ "}" }

// ============ STRINGS AND INTERPOLATION ============
string_literal = ${ "\"" ~ string_inner ~ "\"" }
string_inner = @{ (!"\"" ~ !"\\" ~ ANY | "\\" ~ ANY)* }

string_with_interpolation = ${ "\"" ~ interpolated_content ~ "\"" }
// Capture the raw string body. An interpolation segment `{…}` is consumed as a
// unit so inner quotes (e.g. {t("key")}) don't end the string; everything else
// is a plain char. A `{` only opens an interpolation when immediately followed
// by a non-space expression that closes with `}` on the same line — otherwise
// it is a literal brace, so code samples no longer need to escape `\{` `\}`.
// The same rule is mirrored in the parser (split_interpolated_text).
interpolated_content = @{
    ( "\\" ~ ANY
    | ("{" ~ !" " ~ !"}" ~ (!("}" | "{" | NEWLINE) ~ ANY)* ~ "}")
    | (!"\"" ~ ANY)
    )*
}

// ============ EXPRESSIONS ============
expression = @{ (!("{" | "}") ~ ANY)+ }

// ============ VALUES AND TYPES ============
value = { number | string_literal | boolean | identifier }
boolean = { "true" | "false" }
number = @{ "-"? ~ ASCII_DIGIT+ ~ ("." ~ ASCII_DIGIT+)? }
type_name = @{ ASCII_ALPHA ~ (ASCII_ALPHANUMERIC | "_" | "<" | ">" | ",")* }
identifier = @{ (ASCII_ALPHA | "_") ~ (ASCII_ALPHANUMERIC | "_")* }

