{
  "name": "webcore-language",
  "displayName": "WebCore Language Support",
  "description": "Syntax highlighting and language support for .webc files (WebCore DSL) — v2.5.2",
  "version": "2.5.2",
  "publisher": "webcore",
  "engines": { "vscode": "^1.75.0" },
  "categories": ["Programming Languages"],
  "repository": {
    "type": "git",
    "url": "https://github.com/prinmeshia/webcore"
  },
  "contributes": {
    "languages": [
      {
        "id": "webc",
        "aliases": ["WebCore", "webc"],
        "extensions": [".webc"],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "webc",
        "scopeName": "source.webc",
        "path": "./syntaxes/webc.tmLanguage.json"
      }
    ],
    "snippets": [
      {
        "language": "webc",
        "path": "./snippets/webc.json"
      }
    ]
  }
}
